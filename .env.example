# Cloudflare Pages + D1
# D1 is configured via `wrangler.toml` and the Cloudflare dashboard.

# Stripe (set as Secrets in Cloudflare / wrangler)
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Temporary legacy fallback while local environments are updated
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Local webhook testing: use the signing secret printed by `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin bootstrap (store the bcrypt hash in D1 admin_users; not used as env at runtime)
ADMIN_EMAIL=admin@sunnahskills.com
ADMIN_PASSWORD_HASH=$2a$10$...

# Site
SITE_URL=http://localhost:8788

# MailChannels
EMAIL_FROM=noreply@sunnahskills.pages.dev
EMAIL_TO=mysunnahskill@gmail.com
# Required for production Email API accounts (X-Api-Key header)
MAILCHANNELS_API_KEY=mc_live_...
